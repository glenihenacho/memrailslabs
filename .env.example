# MemRails optional configuration. Copy to `.env.local` and edit as needed.
# All values default to the in-repo layout; nothing here is required to run.

# Canonical, Git-versioned markdown memory (the source of truth).
# MEMRAILS_KNOWLEDGE_DIR=./knowledge

# Append-only JSONL event ledger powering the Console and billing audit.
# MEMRAILS_LEDGER_PATH=./data/logs/ledger.jsonl
